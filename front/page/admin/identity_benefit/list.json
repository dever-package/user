{
  "page": {
    "name": "身份权益",
    "icon": "gift",
    "parent": "user-benefit-assign",
    "sort": 1
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "className": "gap-4"
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5 sm:gap-6",
        "children": {
          "toolbar-row": {
            "type": "row",
            "className": "flex-wrap items-center gap-2.5"
          },
          "table-row": {
            "type": "container",
            "className": "overflow-hidden rounded-md border bg-background"
          },
          "feedback-shell": {
            "type": "container"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page",
        "className": "min-w-0 flex-1"
      }
    ],
    "toolbar-row": [
      {
        "type": "form-input",
        "placeholder": "筛选等级名称...",
        "value": "search.keyword",
        "mode": "search"
      },
      {
        "type": "form-select",
        "placeholder": "身份",
        "value": "search.identity_id",
        "mode": "search",
        "option": "/front/route/option?type=service&use=user.UserOptionService.LoadIdentities",
        "meta": {
          "controlClassName": "w-[180px]"
        }
      },
      {
        "type": "show-button",
        "name": "搜索",
        "meta": {
          "variant": "default",
          "size": "sm",
          "searchSubmit": true,
          "searchLayoutId": "toolbar-row",
          "loadingText": "搜索中..."
        }
      },
      {
        "type": "show-button",
        "name": "重置",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "searchLayoutId": "toolbar-row",
          "to": "/user/identity_benefit/list"
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "rowKey": "id",
          "columns": [
            {
              "value": "identity.name",
              "name": "身份",
              "type": "show-base",
              "className": "text-center"
            },
            {
              "value": "name",
              "name": "等级",
              "type": "show-base",
              "className": "text-center"
            },
            {
              "value": "periodic_benefits",
              "name": "周期权益",
              "type": "show-base",
              "className": "min-w-[360px] whitespace-normal break-words text-center"
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "buttons": [
                  {
                    "icon": "square-pen",
                    "variant": "outline",
                    "size": "sm",
                    "description": "修改权益",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.editLevel",
                          "value": "$row"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.editBenefit",
                          "value": true
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "feedback-shell": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.editBenefit",
          "pageRoute": "/user/identity_benefit/update",
          "title": "修改身份权益",
          "description": "当前只配置周期权益里的奖励积分。",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.editLevel.id"
          },
          "pageDataPatches": {
            "form.id": "data.actionTarget.editLevel.id",
            "form.identity_id": "data.actionTarget.editLevel.identity_id",
            "form.name": "data.actionTarget.editLevel.name",
            "form.level": "data.actionTarget.editLevel.level"
          },
          "size": "2xl",
          "bodyClassName": "py-2"
        }
      }
    ]
  },
  "data": {
    "page": {
      "title": "身份权益",
      "description": "按身份和等级配置周期权益，目前仅支持奖励积分。"
    },
    "search": {
      "keyword": "",
      "identity_id": ""
    },
    "table": {
      "list": "<<user.NewIdentityLevelModel>>",
      "page": 1,
      "pageSize": 10,
      "total": 0,
      "searchFields": [
        "name"
      ],
      "filterFields": [
        "identity_id"
      ],
      "service": "user.BenefitService.AttachIdentityBenefitSummary",
      "order": "identity_id asc,sort asc,level asc,id asc"
    },
    "actionTarget": {
      "editLevel": {}
    }
  },
  "state": {
    "dialog": {
      "editBenefit": false
    }
  },
  "action": {}
}
